#!/bin/bash
set -u

DATA_ROOT="/${TRIM_APPDEST_VOL}/@appshare/sub2api-docker"
DB_NAME="sub2api_fnos"
DB_USER="sub2api_fnos"
IMAGE_TAG="sub2api-fnos:0.1.4"
PREBUILT_IMAGE="__SUB2API_FNOS_IMAGE__"
APP_NAME="sub2api"

detect_volume() {
    if [ -n "${TRIM_APPDEST_VOL:-}" ]; then
        printf '/%s\n' "${TRIM_APPDEST_VOL#/}"
        return 0
    fi
    if [ -n "${TRIM_APPDEST:-}" ]; then
        case "${TRIM_APPDEST}" in
            /vol*/*)
                printf '%s\n' "${TRIM_APPDEST%%/@*}"
                return 0
                ;;
        esac
    fi
    for candidate in /vol*/@appshare/sub2api-docker /vol*/@appcenter/"${APP_NAME}" /vol*/@appmeta/"${APP_NAME}"; do
        if [ -e "${candidate}" ]; then
            printf '%s\n' "${candidate%%/@*}"
            return 0
        fi
    done
    printf '/vol2\n'
}

select_psql() {
    if psql -U postgres -d postgres -tAc 'select 1' >/dev/null 2>&1; then
        PSQL_CMD="psql -U postgres -d postgres"
        return 0
    fi
    if command -v runuser >/dev/null 2>&1 && runuser -u postgres -- psql -d postgres -tAc 'select 1' >/dev/null 2>&1; then
        PSQL_CMD="runuser -u postgres -- psql -d postgres"
        return 0
    fi
    return 1
}

if command -v docker >/dev/null 2>&1; then
    docker rm -f sub2api sub2api-redis >/dev/null 2>&1 || true
    docker volume ls --format '{{.Name}}' | grep -i sub2api | while read -r volume_name; do
        [ -n "${volume_name}" ] && docker volume rm "${volume_name}" >/dev/null 2>&1 || true
    done
    docker network ls --format '{{.Name}}' | grep -i sub2api | while read -r network_name; do
        [ -n "${network_name}" ] && docker network rm "${network_name}" >/dev/null 2>&1 || true
    done
    docker image rm "${IMAGE_TAG}" sub2api-fnos:0.1.3 sub2api-fnos:0.1.2 sub2api-fnos:0.1.1 sub2api-fnos:0.1.0 >/dev/null 2>&1 || true
    if [ -n "${PREBUILT_IMAGE}" ] && [ "${PREBUILT_IMAGE}" != "__SUB2API_FNOS_IMAGE__" ]; then
        docker image rm "${PREBUILT_IMAGE}" >/dev/null 2>&1 || true
    fi
    docker image ls --format '{{.Repository}}:{{.Tag}}' | grep -E '^(sub2api-fnos|ghcr\.io/.*/sub2api-fnos):' | while read -r image_name; do
        [ -n "${image_name}" ] && docker image rm "${image_name}" >/dev/null 2>&1 || true
    done
    docker image rm weishaw/sub2api:latest redis:8-alpine >/dev/null 2>&1 || true
fi

if command -v psql >/dev/null 2>&1 && select_psql; then
    HBA_FILE="$(${PSQL_CMD} -Atc 'show hba_file;' 2>/dev/null | head -n 1)"
    if [ -n "${HBA_FILE}" ] && [ -f "${HBA_FILE}" ]; then
        sed -i '/sub2api-fnos-begin/,/sub2api-fnos-end/d' "${HBA_FILE}" || true
        systemctl reload postgresql >/dev/null 2>&1 || true
    fi

    ${PSQL_CMD} -v ON_ERROR_STOP=0 <<SQL
DO \$\$
BEGIN
  IF EXISTS (SELECT 1 FROM pg_roles WHERE rolname = '${DB_USER}') THEN
    EXECUTE 'REVOKE CONNECT ON DATABASE postgres FROM ${DB_USER}';
    EXECUTE 'REVOKE CONNECT ON DATABASE ${DB_NAME} FROM ${DB_USER}';
  END IF;
END
\$\$;
REVOKE CONNECT ON DATABASE ${DB_NAME} FROM PUBLIC;
SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = '${DB_NAME}';
DROP DATABASE IF EXISTS ${DB_NAME};
DO \$\$
BEGIN
  IF EXISTS (SELECT 1 FROM pg_roles WHERE rolname = '${DB_USER}') THEN
    EXECUTE 'DROP OWNED BY ${DB_USER}';
  END IF;
END
\$\$;
DROP ROLE IF EXISTS ${DB_USER};
SQL
fi

APP_VOL="$(detect_volume)"
rm -rf \
    "${DATA_ROOT}" \
    "${APP_VOL}/@appshare/sub2api-docker" \
    "${APP_VOL}/@appcenter/${APP_NAME}" \
    "${APP_VOL}/@appconf/${APP_NAME}" \
    "${APP_VOL}/@apphome/${APP_NAME}" \
    "${APP_VOL}/@appmeta/${APP_NAME}" \
    "${TRIM_PKGVAR:-/var/empty/sub2api-unused}" \
    /vol*/@appshare/sub2api-docker \
    /vol*/@appcenter/"${APP_NAME}" \
    /vol*/@appconf/"${APP_NAME}" \
    /vol*/@apphome/"${APP_NAME}" \
    /vol*/@appmeta/"${APP_NAME}" \
    /vol*/appcenter-downloads/"${APP_NAME}"-* \
    "/var/log/apps/${APP_NAME}.log" \
    "/var/log/apps/${APP_NAME}" \
    "/var/packages/${APP_NAME}" \
    "/var/apps/${APP_NAME}" \
    "/var/appdata/${APP_NAME}"

exit 0
