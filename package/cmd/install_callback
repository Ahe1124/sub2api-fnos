#!/bin/bash
set -u

APP_NAME="sub2api"
APP_SHARE="sub2api-docker"
IMAGE_TAG="sub2api-fnos:0.1.3"
PREBUILT_IMAGE="__SUB2API_FNOS_IMAGE__"

log() {
    echo "[sub2api install] $*"
}

fail() {
    echo "[sub2api install] ERROR: $*" >&2
    exit 1
}

gen_secret() {
    if command -v openssl >/dev/null 2>&1; then
        openssl rand -hex 32
    else
        tr -dc 'A-Za-z0-9' </dev/urandom | head -c 64
        echo
    fi
}

detect_volume() {
    if [ -n "${TRIM_APPDEST_VOL:-}" ]; then
        printf '/%s\n' "${TRIM_APPDEST_VOL#/}"
        return 0
    fi
    if [ -n "${TRIM_APPDEST:-}" ]; then
        case "${TRIM_APPDEST}" in
            /vol*/*)
                printf '%s\n' "${TRIM_APPDEST%%/@*}"
                return 0
                ;;
        esac
    fi
    for candidate in /vol*/@appshare/"${APP_SHARE}" /vol*/@appcenter/"${APP_NAME}" /vol*/@appmeta/"${APP_NAME}"; do
        if [ -e "${candidate}" ]; then
            printf '%s\n' "${candidate%%/@*}"
            return 0
        fi
    done
    printf '/vol2\n'
}

APP_VOL="$(detect_volume)"
TRIM_APPDEST_VOL="${APP_VOL#/}"
export TRIM_APPDEST_VOL
DATA_ROOT="${APP_VOL}/@appshare/${APP_SHARE}"
ENV_FILE="${DATA_ROOT}/sub2api.env"

read_env_value() {
    key="$1"
    [ -s "${ENV_FILE}" ] || return 1
    sed -n "s/^${key}=//p" "${ENV_FILE}" | head -n 1 | sed 's/^"//;s/"$//'
}

escape_env_value() {
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

write_env_line() {
    key="$1"
    value="$2"
    printf '%s="%s"\n' "$key" "$(escape_env_value "$value")"
}

find_docker_dir() {
    for candidate in \
        "${TRIM_APPDEST:-}/docker" \
        "$(cd "$(dirname "$0")" && pwd)/docker" \
        "$(cd "$(dirname "$0")" && pwd)/../app/docker" \
        "$(cd "$(dirname "$0")" && pwd)/../docker" \
        "${APP_VOL}/@appcenter/${APP_NAME}/docker" \
        "${APP_VOL}/@appmeta/${APP_NAME}/cmd/docker"
    do
        if [ -n "${candidate}" ] && [ -f "${candidate}/Dockerfile" ]; then
            printf '%s\n' "${candidate}"
            return 0
        fi
    done
    return 1
}

find_compose_file() {
    script_dir="$(cd "$(dirname "$0")" && pwd)"

    for candidate in \
        "${TRIM_APPDEST:-}/docker/docker-compose.yaml" \
        "${script_dir}/docker/docker-compose.yaml" \
        "${script_dir}/../app/docker/docker-compose.yaml" \
        "${script_dir}/../docker/docker-compose.yaml" \
        "${APP_VOL}/@appcenter/${APP_NAME}/docker/docker-compose.yaml" \
        "${APP_VOL}/@appmeta/${APP_NAME}/cmd/docker/docker-compose.yaml" \
        /vol*/@appcenter/"${APP_NAME}"/docker/docker-compose.yaml \
        /vol*/@appmeta/"${APP_NAME}"/cmd/docker/docker-compose.yaml
    do
        if [ -f "${candidate}" ]; then
            printf '%s\n' "${candidate}"
            return 0
        fi
    done
    return 1
}

prepare_app_image() {
    if ! command -v docker >/dev/null 2>&1; then
        fail "docker command not found"
    fi

    if docker inspect -f '{{.State.Running}}' "${APP_NAME}" 2>/dev/null | grep -q true; then
        log "${APP_NAME} container is already running; skip image rebuild"
        return 0
    fi

    docker rm -f "${APP_NAME}" "${APP_NAME}-redis" >/dev/null 2>&1 || true

    if [ -n "${PREBUILT_IMAGE}" ] && [ "${PREBUILT_IMAGE}" != "__SUB2API_FNOS_IMAGE__" ]; then
        log "pulling prebuilt image ${PREBUILT_IMAGE}"
        if docker pull "${PREBUILT_IMAGE}" && docker tag "${PREBUILT_IMAGE}" "${IMAGE_TAG}"; then
            log "prepared ${IMAGE_TAG} from ${PREBUILT_IMAGE}"
            return 0
        fi
        log "prebuilt image pull failed; falling back to local build"
    fi

    DOCKER_DIR="$(find_docker_dir)" || fail "docker package directory not found"
    docker build --pull -t "${IMAGE_TAG}" "${DOCKER_DIR}" || fail "failed to build ${IMAGE_TAG}"
}

start_app() {
    if ! command -v docker >/dev/null 2>&1 || ! docker info >/dev/null 2>&1; then
        fail "docker is not available"
    fi
    COMPOSE_FILE="$(find_compose_file)" || fail "docker-compose.yaml not found"
    docker compose -p "${APP_NAME}" -f "${COMPOSE_FILE}" up -d --remove-orphans || fail "failed to start ${APP_NAME}"
}

mkdir -p \
    "${DATA_ROOT}/data" \
    "${DATA_ROOT}/data/postgresql" \
    "${DATA_ROOT}/data/postgresql-run" \
    "${DATA_ROOT}/data/redis" \
    "${DATA_ROOT}/data/logs"
chmod 700 \
    "${DATA_ROOT}" \
    "${DATA_ROOT}/data" \
    "${DATA_ROOT}/data/postgresql" \
    "${DATA_ROOT}/data/postgresql-run" \
    "${DATA_ROOT}/data/redis" 2>/dev/null || true

if [ -s "${ENV_FILE}" ]; then
    DATABASE_PASSWORD="$(read_env_value DATABASE_PASSWORD)"
    REDIS_PASSWORD="$(read_env_value REDIS_PASSWORD)"
    JWT_SECRET="$(read_env_value JWT_SECRET)"
    TOTP_ENCRYPTION_KEY="$(read_env_value TOTP_ENCRYPTION_KEY)"
else
    DATABASE_PASSWORD="$(gen_secret)"
    REDIS_PASSWORD="$(gen_secret)"
    JWT_SECRET="$(gen_secret)"
    TOTP_ENCRYPTION_KEY="$(gen_secret)"
fi
[ -n "${DATABASE_PASSWORD:-}" ] || DATABASE_PASSWORD="$(gen_secret)"
[ -n "${REDIS_PASSWORD:-}" ] || REDIS_PASSWORD="$(gen_secret)"
[ -n "${JWT_SECRET:-}" ] || JWT_SECRET="$(gen_secret)"
[ -n "${TOTP_ENCRYPTION_KEY:-}" ] || TOTP_ENCRYPTION_KEY="$(gen_secret)"

ADMIN_EMAIL="${wizard_admin_email:-admin@sub2api.local}"
ADMIN_PASSWORD="${wizard_admin_password:-}"
UPDATE_PROXY_URL="${wizard_update_proxy_url:-}"

umask 077
{
    write_env_line DATABASE_HOST "127.0.0.1"
    write_env_line DATABASE_PORT "15432"
    write_env_line DATABASE_USER "sub2api_fnos"
    write_env_line DATABASE_PASSWORD "${DATABASE_PASSWORD}"
    write_env_line DATABASE_DBNAME "sub2api_fnos"
    write_env_line DATABASE_SSLMODE "disable"
    write_env_line DATABASE_MAX_OPEN_CONNS "50"
    write_env_line DATABASE_MAX_IDLE_CONNS "10"
    write_env_line DATABASE_CONN_MAX_LIFETIME_MINUTES "30"
    write_env_line DATABASE_CONN_MAX_IDLE_TIME_MINUTES "5"
    write_env_line POSTGRES_BIND "127.0.0.1"
    write_env_line POSTGRES_PORT "15432"
    write_env_line POSTGRES_DB "sub2api_fnos"
    write_env_line POSTGRES_USER "sub2api_fnos"
    write_env_line POSTGRES_PASSWORD "${DATABASE_PASSWORD}"
    write_env_line POSTGRES_DATA_DIR "/app/data/postgresql"
    write_env_line POSTGRES_RUN_DIR "/app/data/postgresql-run"
    write_env_line REDIS_HOST "127.0.0.1"
    write_env_line REDIS_PORT "16379"
    write_env_line REDIS_PASSWORD "${REDIS_PASSWORD}"
    write_env_line REDIS_DB "0"
    write_env_line REDIS_POOL_SIZE "1024"
    write_env_line REDIS_MIN_IDLE_CONNS "10"
    write_env_line REDIS_ENABLE_TLS "false"
    write_env_line REDIS_DATA_DIR "/app/data/redis"
    write_env_line SUB2API_WRITE_CONFIG "true"
    write_env_line ADMIN_EMAIL "${ADMIN_EMAIL}"
    write_env_line ADMIN_PASSWORD "${ADMIN_PASSWORD}"
    write_env_line JWT_SECRET "${JWT_SECRET}"
    write_env_line JWT_EXPIRE_HOUR "24"
    write_env_line TOTP_ENCRYPTION_KEY "${TOTP_ENCRYPTION_KEY}"
    write_env_line UPDATE_PROXY_URL "${UPDATE_PROXY_URL}"
} > "${ENV_FILE}"
chmod 600 "${ENV_FILE}"

prepare_app_image
log "prepared embedded PostgreSQL, Redis and application data in ${DATA_ROOT}"
start_app
log "started ${APP_NAME}"
exit 0
