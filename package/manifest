display_name=Sub2API
desc="""<p><strong>Intro:</strong> Sub2API is an AI API gateway for API keys, account pools, billing, load balancing and request forwarding.</p><p><strong>Packaging:</strong> fnOS Docker app. The app runs as a single <code>sub2api</code> container on host network. Sub2API listens on <code>0.0.0.0:8088</code>.</p><p><strong>Storage:</strong> PostgreSQL and Redis are embedded inside the same container. PostgreSQL listens on <code>127.0.0.1:15432</code>, Redis listens on <code>127.0.0.1:16379</code>, and both store data under the selected app data volume at <code>@appshare/sub2api-docker/data</code>.</p><p><strong>Uninstall cleanup:</strong> Removes the container, local/prebuilt images, app data directories, logs, Docker resources, and legacy system PostgreSQL database/role if they exist.</p><p><strong>Source:</strong> <a href="https://github.com/Wei-Shaw/sub2api" target="_blank">Wei-Shaw/sub2api</a></p>"""
platform=all
source=thirdparty
maintainer=Wei-Shaw
maintainer_url=https://github.com/Wei-Shaw/sub2api
distributor=local
distributor_url=https://github.com/Wei-Shaw/sub2api
desktop_uidir=ui
desktop_applaunchname=sub2api.proxy.Application
service_port=8088
checkport=true
changelog=Embed PostgreSQL and Redis in the single host-network container so all app data follows the selected fnOS install volume, while keeping uninstall cleanup compatible with legacy system PostgreSQL installs.
